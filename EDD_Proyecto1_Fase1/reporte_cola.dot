digraph G {
  rankdir=LR;
  node [shape=record, style=filled, fillcolor="#a1cdd8"];

  Frente [shape=plaintext, style=solid];
  Fin [shape=plaintext, style=solid];

  nodo0 [label="{Pedido #1 | Finca La Hermosa | 200 Qq}"];
  nodo1 [label="{Pedido #2 | Finca Las Nubes | 60 Qq}"];

  Frente -> nodo0;
  nodo0 -> nodo1;
  nodo1 -> Fin;
}
